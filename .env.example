# ============================================================
# Sister AI Agent — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# -- Anthropic (Claude API) --
ANTHROPIC_API_KEY=sk-ant-xxxxx

# -- Telegram Bot (the bot your sister talks to) --
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Your sister's Telegram user ID (for access control — only she can use the bot)
TELEGRAM_ALLOWED_USER_ID=123456789

# -- Telegram Client (reading her personal messages) --
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890
TELEGRAM_PHONE=+1234567890

# -- Gmail + Google Calendar --
# Path to OAuth credentials JSON downloaded from Google Cloud Console
GOOGLE_CREDENTIALS_PATH=config/credentials.json
# Token gets auto-generated after first OAuth flow (auth_google.py)
GOOGLE_TOKEN_PATH=config/token.json

# -- Telegram session --
# Path where Telethon persists the authenticated session (auth_telegram.py)
TELEGRAM_SESSION_PATH=config/telegram.session

# -- WhatsApp --
# TBD — will be configured in Module 4

# -- Database --
DB_PATH=~/.sister-agent/messages.db
